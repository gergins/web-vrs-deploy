NODE_ENV=development

WEB_PORT=3000
API_PORT=3001
# Change this to any free local port, for example 5434, if 5433 is occupied.
POSTGRES_HOST_PORT=5433
# Change this to any free local port, for example 6380, if 6379 is occupied.
REDIS_HOST_PORT=6379

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/vrs
# Keep this host port aligned with POSTGRES_HOST_PORT for local Prisma/API access.
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/vrs
REDIS_URL=redis://redis:6379

JWT_SECRET=change-me
SESSION_COOKIE_SECRET=change-me

PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_BASE_URL=http://localhost:3001
PUBLIC_WS_URL=ws://localhost:3001/ws
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

TURN_HOST=localhost
TURN_REALM=localhost
TURN_PORT=3478
TURN_TLS_PORT=0
# Legacy static credentials kept for existing non-backend client config paths.
TURN_USERNAME=test
TURN_PASSWORD=test
# Authoritative local shared secret for backend-generated temporary TURN credentials.
TURN_SHARED_SECRET=change-me
TURN_CREDENTIAL_TTL_SECONDS=3600

NEXT_PUBLIC_STUN_URL=stun:localhost:3478
NEXT_PUBLIC_TURN_URL=turn:localhost:3478
NEXT_PUBLIC_TURN_USERNAME=test
NEXT_PUBLIC_TURN_PASSWORD=test

CORS_ORIGIN=http://localhost:3000,http://localhost:3001
LOG_LEVEL=info
RECONNECT_GRACE_MS=30000
QUEUE_OFFER_TIMEOUT_MS=20000
SESSION_HEARTBEAT_INTERVAL_MS=10000
