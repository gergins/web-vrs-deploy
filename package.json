{
  "name": "web-vrs",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "pnpm --dir apps/api dev",
    "demo:infra": "docker compose up -d postgres redis coturn",
    "demo:api": "pnpm --dir apps/api dev",
    "demo:web": "pnpm --dir apps/web dev",
    "demo:api:direct": "pnpm --dir apps/api dev:direct",
    "demo:web:direct": "pnpm --dir apps/web dev:direct",
    "demo:api:built": "pnpm --dir apps/api start:local:built",
    "demo:web:built": "pnpm --dir apps/web start:built",
    "demo": "pnpm demo:infra",
    "build": "pnpm -r build",
    "build:api": "pnpm --dir apps/api build",
    "build:web": "pnpm --dir apps/web build",
    "test:e2e:happy-path": "node tests/e2e/authenticated-happy-path.mjs",
    "test:e2e:simultaneous-offer": "node tests/e2e/simultaneous-offer-fanout.mjs",
    "test:e2e:hangup-reoffer": "node tests/e2e/hangup-reoffer-eligibility.mjs",
    "test:e2e:disconnect-grace": "node tests/e2e/disconnect-grace-active-session.mjs",
    "test:e2e:stale-call-url": "node tests/e2e/stale-interpreter-call-url.mjs",
    "test:e2e:core": "pnpm.cmd test:e2e:happy-path && pnpm.cmd test:e2e:simultaneous-offer && pnpm.cmd test:e2e:hangup-reoffer && pnpm.cmd test:e2e:disconnect-grace",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --dir apps/api prisma:generate",
    "db:push": "pnpm --dir apps/api prisma:push:local",
    "db:migrate": "pnpm --dir apps/api prisma:migrate:local",
    "db:seed": "pnpm --dir apps/api prisma:seed",
    "up": "docker compose up --build",
    "down": "docker compose down"
  },
  "devDependencies": {
    "prisma": "^7.5.0",
    "ws": "^8.18.0"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0"
  }
}
