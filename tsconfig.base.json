{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@contracts/*": ["packages/contracts/src/*"],
      "@shared/*": ["packages/shared/src/*"],
      "@webrtc/*": ["packages/webrtc/src/*"],
      "@ui/*": ["packages/ui/src/*"]
    }
  }
}
